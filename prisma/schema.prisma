// SpaceDifabel - Database Schema
// Supabase PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USERS
// ============================================
model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  password        String
  disability_type String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  job_applications JobApplication[]

  @@map("users")
}

// ============================================
// COURSES
// ============================================
model Course {
  id            String   @id @default(uuid())
  title         String
  description   String
  category      String
  target        String   // target disability type
  thumbnail_url String?
  instructor    String
  duration      String?  // e.g. "2 jam", "30 menit"
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  materials CourseMaterial[]

  @@map("courses")
}

model CourseMaterial {
  id           String   @id @default(uuid())
  course_id    String
  title        String
  content      String   @db.Text
  content_type String   // "video", "text", "audio"
  order        Int
  created_at   DateTime @default(now())

  course Course @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@map("course_materials")
}

// ============================================
// JOBS
// ============================================
model Job {
  id           String   @id @default(uuid())
  title        String
  company      String
  description  String   @db.Text
  category     String
  target       String   // target disability type
  location     String
  salary_range String?
  requirements String?  @db.Text
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  applications JobApplication[]

  @@map("jobs")
}

model JobApplication {
  id           String   @id @default(uuid())
  job_id       String
  user_id      String
  cv_url       String   // URL file di Supabase Storage
  cover_letter String?  @db.Text
  status       String   @default("pending") // pending, reviewed, accepted, rejected
  created_at   DateTime @default(now())

  job  Job  @relation(fields: [job_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("job_applications")
}

// ============================================
// ARTICLES
// ============================================
model Article {
  id            String   @id @default(uuid())
  title         String
  content       String   @db.Text
  category      String
  thumbnail_url String?
  author        String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("articles")
}
